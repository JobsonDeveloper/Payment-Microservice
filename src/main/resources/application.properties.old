spring.application.name=payment microservice
server.port=
spring.application.zone=America/Recife
application.currency.id=BRL

sale.micro.url=
client.micro.url=

#Database
MONGO_HOST=
MONGO_PORT=
MONGO_DB=paymentdb
MONGO_USER=
MONGO_PASS=
spring.data.mongodb.uri=mongodb://${MONGO_USER}:${MONGO_PASS}@${MONGO_HOST}:${MONGO_PORT}/${MONGO_DB}?authSource=admin

#Apache Kafka
spring.kafka.bootstrap-servers=
spring.kafka.producer.key-serializer=org.apache.kafka.common.serialization.StringSerializer
spring.kafka.producer.value-serializer=org.springframework.kafka.support.serializer.JsonSerializer
spring.kafka.producer.properties.spring.json.add.type.headers=false

spring.kafka.consumer.bootstrap-servers=
spring.kafka.consumer.group-id=payment-group

spring.kafka.consumer.key-deserializer=org.springframework.kafka.support.serializer.ErrorHandlingDeserializer
spring.kafka.consumer.value-deserializer=org.springframework.kafka.support.serializer.ErrorHandlingDeserializer
spring.kafka.consumer.properties.spring.json.value.default.type=br.com.payment.micro.event.dto.CancelPaymentEventDto
spring.kafka.consumer.properties.spring.deserializer.key.delegate.class=org.apache.kafka.common.serialization.StringDeserializer
spring.kafka.consumer.properties.spring.deserializer.value.delegate.class=org.springframework.kafka.support.serializer.JsonDeserializer

spring.kafka.consumer.properties.spring.json.trusted.packages=*

#Mercado pago
e-sale.access.token=
e-sale.payment.webhook.key=
mercado-pago.payment.back.url.success=
mercado-pago.payment.back.url.pending=
mercado-pago.payment.back.url.failure=
mercado-pago.payment.notification.url=